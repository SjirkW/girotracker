{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "girotracker",
  "main": "worker/index.ts",
  "compatibility_date": "2026-04-25",
  "build": {
    "command": "npm install --prefix web && npm run build --prefix web"
  },
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}
